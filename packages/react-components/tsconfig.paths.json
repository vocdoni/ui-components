{
  "extends": "tsconfig/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~components": ["src/components"],
      "~components/*": ["src/components/*"],
      "~confirm": ["src/confirm"],
      "~confirm/*": ["src/confirm/*"],
      "~i18n": ["src/i18n"],
      "~i18n/*": ["src/i18n/*"],
      "~providers": ["src/providers"],
      "~providers/*": ["src/providers/*"],
      "~src": ["src"],
      "~src/*": ["src/*"]
    }
  }
}
